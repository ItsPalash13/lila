# Nakama HTTP / WebSocket client (Vite: only VITE_* vars are exposed to the browser)

# API key from Nakama console / server config (default local dev key)
# VITE_NAKAMA_SERVER_KEY=defaultkey

# Hostname or IP of your Nakama server
# VITE_NAKAMA_HOST=127.0.0.1

# API + realtime port (plain HTTP/WS). Often 7350 locally.
# VITE_NAKAMA_PORT=7350

# Production: set to "true" when the site is served over HTTPS so the client uses
# wss:// and https:// against Nakama (or your TLS-terminated proxy). Avoid mixed
# content: the page origin and Nakama/WSS endpoint must both be secure, or both
# non-secure in development.
# VITE_NAKAMA_USE_SSL=true
