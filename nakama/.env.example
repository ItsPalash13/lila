# Optional secrets for local tooling (never commit `.env`).
#
# Default `docker compose up` uses the Postgres service in docker-compose.yml and
# does not need this file. Use a URL like below only if you point Nakama at an
# external Postgres (custom compose / Dockerfile run):
#
# NAKAMA_DATABASE_ADDRESS=postgres://USER:PASSWORD@HOST:5432/nakama?sslmode=require
#
# URL-encode special characters in USER/PASSWORD (e.g. @ → %40).
